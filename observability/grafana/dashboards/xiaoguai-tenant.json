  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["xiaoguai", "tenant"],
  "templating": {
    "list": [
      {
        "current": {
          "selected": false,
          "text": "All",
          "value": "$__all"
        },
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(xiaoguai_request_total, tenant)",
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "name": "tenant",
        "options": [],
        "query": {
          "query": "label_values(xiaoguai_request_total, tenant)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Tenant"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
