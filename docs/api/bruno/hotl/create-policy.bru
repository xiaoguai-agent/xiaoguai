meta {
  name: Create HOTL Policy
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/v1/hotl/policies
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "tenant_id": "{{tenantId}}",
    "scope": "llm_call",
    "window_seconds": 3600,
    "max_count": 100,
    "max_usd": 5.00,
    "escalate_to": "ops@example.com"
  }
}

assert {
  res.status: eq 201
  res.body.id: isDefined
  res.body.tenant_id: eq {{tenantId}}
  res.body.scope: eq llm_call
  res.body.window_seconds: eq 3600
}
