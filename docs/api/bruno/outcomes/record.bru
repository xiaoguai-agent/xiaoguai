meta {
  name: Record Outcome
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/v1/outcomes
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "tenant_id": "tenant_acme",
    "session_id": "sess_abc123",
    "agent_name": "sales-bot",
    "kind": "revenue_usd",
    "value": 1500.00,
    "unit": "usd",
    "description": "Closed enterprise deal via automated follow-up",
    "metadata": {
      "deal_id": "deal_789",
      "account": "Acme Corp"
    }
  }
}

assert {
  res.status: eq 201
  res.body.ok: eq true
}
