meta {
  name: Outcomes Timeseries (bar chart)
  type: http
  seq: 4
}

get {
  url: {{baseUrl}}/v1/outcomes/timeseries
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

params:query {
  tenant_id: tenant_acme
  range: 7d
  ~kind: revenue_usd
}

assert {
  res.status: eq 200
  res.body.tenant_id: eq tenant_acme
  res.body.range: eq 7d
  res.body.days: isArray
}
