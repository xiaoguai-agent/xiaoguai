# .env.local.example — copy to .env.local and edit before running
# scripts/local-experiment.sh.
#
#   cp .env.local.example .env.local
#   $EDITOR .env.local
#
# Only OPENAI_API_KEY is required. Everything else has a sensible default.

# ── REQUIRED ──────────────────────────────────────────────────────────
# Your OpenAI / Codex / OpenAI-compatible reseller API key.
# Format: starts with "sk-..." for OpenAI proper.
OPENAI_API_KEY=sk-REPLACE-ME

# ── OPTIONAL ──────────────────────────────────────────────────────────

# OpenAI-compatible base URL. Default = OpenAI proper.
# If you're using a Chinese reseller / proxy / Codex relay, override
# to that endpoint. Examples:
#   https://api.openai.com/v1            (default — OpenAI proper)
#   https://api.deepseek.com/v1          (DeepSeek)
#   https://dashscope.aliyuncs.com/compatible-mode/v1  (Alibaba 通义)
#   https://your-codex-proxy.example/v1  (whatever your codex relay is)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Default model name. Pick one your endpoint supports.
#   gpt-4o-mini    — recommended baseline for UI testing (fast + cheap)
#   gpt-4o         — better tool-call quality, ~10× cost
#   deepseek-chat  — if you point base-url at DeepSeek
# OPENAI_MODEL=gpt-4o-mini

# Provider name in the LlmRouter registry. Show up under this name in
# the admin-ui Providers pane. "codex" is a fine label; "openai" is
# fine too. Must be unique per tenant (or global when --tenant absent).
# PROVIDER_NAME=codex

# Comma-separated marketplace MCP server slugs to install at boot.
# These appear as tool-call sources in the chat-ui and as rows in the
# admin-ui MCP Servers pane. Default = the two npx-available reference
# servers (no Python toolchain needed).
#
# Available slugs (catalog/mcp_marketplace.json):
#   filesystem  npx — read/write local files (sandboxed by MCP)
#   memory      npx — lightweight knowledge-graph KV store
#   github      npx — needs GITHUB_TOKEN env var; skip unless you set it
#   postgres    npx — needs a writable PG connection string
#   slack       npx — needs SLACK_BOT_TOKEN + SLACK_APP_TOKEN
#   obsidian    npx — needs an actual vault path baked into the command
#   fetch       uvx — needs Python + uv installed locally
#   sqlite      uvx — needs Python + uv installed locally
#
# `uvx`-based servers fail-skip in our compose container (distroless,
# no Python). If you want to try them, run xiaoguai-core bare-metal
# and install `uv` first (https://github.com/astral-sh/uv).
# MARKETPLACE_INSTALL=filesystem,memory

# Skip the `pnpm install` step (set to anything non-empty).
# Useful if your node_modules is already warm.
# SKIP_FRONTEND_INSTALL=1
