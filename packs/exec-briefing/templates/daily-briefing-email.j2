{# templates/daily-briefing-email.j2
   Daily KPI briefing email — rendered by exec-narrator output step.
   Consumed by outputs/exec-team-email-digest.yaml.
   Plain HTML with inline styles for maximum email client compatibility.
#}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ narrative.subject_line }}</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
             font-size: 14px; color: #1a1a1a; max-width: 640px; margin: 0 auto; padding: 24px;">

  {# ── Header ─────────────────────────────────────────────────────────── #}
  <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 24px;">
    <tr>
      <td>
        <p style="margin: 0; font-size: 11px; color: #666; text-transform: uppercase;
                  letter-spacing: 0.08em;">Daily KPI Briefing</p>
        <h1 style="margin: 4px 0 0; font-size: 20px; font-weight: 600; color: #111;">
          {{ narrative.subject_line }}
        </h1>
        <p style="margin: 6px 0 0; font-size: 13px; color: #555;">
          {{ narrative.period_label }} &nbsp;·&nbsp; Generated {{ generated_at | format_datetime }}
        </p>
      </td>
    </tr>
  </table>

  {# ── 5-bullet narrative ────────────────────────────────────────────── #}
  <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 28px;
         background: #f8f9fa; border-radius: 8px; padding: 20px;">
    <tr><td>
      <p style="margin: 0 0 12px; font-size: 12px; font-weight: 600; color: #666;
                text-transform: uppercase; letter-spacing: 0.07em;">Summary</p>
      <ul style="margin: 0; padding-left: 20px;">
        {% for bullet in narrative.bullets %}
        <li style="margin-bottom: 10px; line-height: 1.5; color:
          {% if bullet.sentiment == 'positive' %}#166534
          {% elif bullet.sentiment == 'negative' %}#991b1b
          {% else %}#1a1a1a{% endif %};">
          {{ bullet.text }}
        </li>
        {% endfor %}
      </ul>
      {% if narrative.data_quality_notes %}
      <p style="margin: 14px 0 0; font-size: 12px; color: #777; font-style: italic;">
        Data notes: {{ narrative.data_quality_notes | join(" · ") }}
      </p>
      {% endif %}
    </td></tr>
  </table>

  {# ── Anomaly callouts (urgent + significant only for daily) ─────────── #}
  {% set urgent_callouts = callouts | selectattr('severity', 'in', ['urgent', 'significant']) | list %}
  {% if urgent_callouts %}
  <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 28px;">
    <tr><td>
      <p style="margin: 0 0 12px; font-size: 12px; font-weight: 600; color: #666;
                text-transform: uppercase; letter-spacing: 0.07em;">Anomaly Callouts</p>
      {% for callout in urgent_callouts %}
      {% include 'templates/anomaly-callout-block.j2' %}
      {% endfor %}
    </td></tr>
  </table>
  {% endif %}

  {# ── P0 actions (urgent anomalies only on daily) ──────────────────── #}
  {% set p0_actions = actions | selectattr('priority', 'equalto', 'P0') | list %}
  {% if p0_actions %}
  <table width="100%" cellpadding="0" cellspacing="0" style="margin-bottom: 28px;
         border: 1px solid #fee2e2; border-radius: 8px; padding: 16px; background: #fff5f5;">
    <tr><td>
      <p style="margin: 0 0 10px; font-size: 12px; font-weight: 600; color: #991b1b;
                text-transform: uppercase; letter-spacing: 0.07em;">Actions Required Today</p>
      {% for action in p0_actions %}
      <p style="margin: 0 0 8px; line-height: 1.5;">
        <strong>{{ action.owner_role }}</strong>: {{ action.action_text }}
      </p>
      {% endfor %}
    </td></tr>
  </table>
  {% endif %}

  {# ── Footer ─────────────────────────────────────────────────────────── #}
  <p style="font-size: 11px; color: #999; border-top: 1px solid #e5e7eb; padding-top: 16px;
            margin-top: 16px;">
    Generated by xiaoguai exec-briefing pack v{{ pack_version }}.
    <a href="{{ briefing_url }}" style="color: #6b7280;">View full dashboard</a>
    &nbsp;·&nbsp;
    <a href="{{ unsubscribe_url }}" style="color: #6b7280;">Unsubscribe</a>
  </p>

</body>
</html>
