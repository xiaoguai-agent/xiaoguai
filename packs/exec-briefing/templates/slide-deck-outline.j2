{# templates/slide-deck-outline.j2
   Generates a plain-text slide deck outline for weekly / monthly briefings.
   Consumed by outputs/slides-stub-export.yaml which writes it to GCS as a
   .txt file that a human can paste into Google Slides / PowerPoint speaker notes.
   Intentionally plain text — no HTML — so it renders cleanly in any context.
#}
EXEC BRIEFING — SLIDE DECK OUTLINE
{{ narrative.period_label | upper }}
Generated: {{ generated_at | format_datetime }}
================================================================================

SLIDE 1 — TITLE
  {{ narrative.subject_line }}
  {{ narrative.period_label }}
  Prepared by: [Name / Team]
  Date: {{ generated_at | format_date }}

================================================================================

SLIDE 2 — EXECUTIVE SUMMARY (5 bullets)
{% for bullet in narrative.bullets %}
  • {{ bullet.text }}
{% endfor %}
{% if narrative.data_quality_notes %}

  [Data notes: {{ narrative.data_quality_notes | join("; ") }}]
{% endif %}

================================================================================

SLIDE 3 — NORTH-STAR METRIC
{% set ns = snapshot.observations | selectattr('category', 'equalto', 'north_star') | list %}
{% for obs in ns %}
  Metric: {{ obs.metric_label }}
  Current: {{ obs.current_value | format_kpi }}
  {{ 'WoW' if snapshot.period_type != 'monthly' else 'MoM' }}: {{ obs.period_over_period_pct | format_pct(sign=true) }}
  Prior period: {{ obs.prior_period_value | format_kpi }}
  [Insert trend chart]
{% endfor %}

================================================================================

SLIDE 4 — REVENUE & COMMERCIAL
{% set rev = snapshot.observations | selectattr('category', 'equalto', 'revenue') | list %}
{% for obs in rev %}
  {{ obs.metric_label }}: {{ obs.current_value | format_kpi }}  ({{ obs.period_over_period_pct | format_pct(sign=true) }})
{% endfor %}
  [Insert revenue waterfall chart]

================================================================================

SLIDE 5 — GROWTH
{% set growth = snapshot.observations | selectattr('category', 'equalto', 'growth') | list %}
{% for obs in growth %}
  {{ obs.metric_label }}: {{ obs.current_value | format_kpi }}  ({{ obs.period_over_period_pct | format_pct(sign=true) }})
{% endfor %}
  [Insert growth funnel chart]

================================================================================

SLIDE 6 — RETENTION & ENGAGEMENT
{% set ret = snapshot.observations | selectattr('category', 'equalto', 'retention') | list %}
{% for obs in ret %}
  {{ obs.metric_label }}: {{ obs.current_value | format_kpi }}  ({{ obs.period_over_period_pct | format_pct(sign=true) }})
{% endfor %}
  [Insert retention cohort chart]

================================================================================

SLIDE 7 — OPERATIONAL HEALTH
{% set ops = snapshot.observations | selectattr('category', 'equalto', 'ops') | list %}
{% for obs in ops %}
  {{ obs.metric_label }}: {{ obs.current_value | format_kpi }}  ({{ obs.period_over_period_pct | format_pct(sign=true) }})
{% endfor %}
  [Insert SLO dashboard screenshot]

================================================================================
{% if callouts %}

SLIDE 8 — ANOMALY CALLOUTS
{% for callout in callouts | sort(attribute='severity', reverse=true) %}
  [{{ callout.exec_severity_label | upper }}] {{ callout.kpi_label }}
  {{ callout.headline }}
  {{ callout.explanation }}
  Signal: {{ callout.signal_note }}

{% endfor %}
================================================================================
{% endif %}

{% if actions %}
SLIDE {{ '9' if callouts else '8' }} — RECOMMENDED ACTIONS
{% for action in actions | sort(attribute='priority') %}
  {{ action.priority }}  {{ action.owner_role }}: {{ action.action_text }} (by {{ action.deadline | replace('_', ' ') }})
{% endfor %}
================================================================================
{% endif %}

SLIDE {{ loop_last_slide }} — APPENDIX / Q&A
  [Additional charts, methodology notes, data source details]

================================================================================
Generated by xiaoguai exec-briefing pack v{{ pack_version }}.
